# Render.com Environment Variables Template
# Copy to Render dashboard or use as reference

# Server
PORT=8080

# Database (PostgreSQL)
DB_URL=jdbc:postgresql://postgres-host.render.internal:5432/tirupurconnect
DB_USER=postgres
DB_PASS=your-secure-password

# Redis
REDIS_HOST=redis-host.render.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-256-bit-secret-key-generate-with-openssl-rand-hex-32
JWT_EXPIRY_MS=86400000

# Elasticsearch
ES_HOST=elasticsearch-host.render.internal
ES_PORT=9200
ES_USER=elastic
ES_PASS=your-elasticsearch-password

# WhatsApp
WA_PROVIDER=mock
WA_API_URL=https://api.gupshup.io/sm/api/v1/msg
WA_API_KEY=your-gupshup-api-key
WA_SOURCE=+919999999999

